        ff11 = ff11 + cff10; var cff11: int = ff11 / 256; ff11 = ff11 % 256
        ff12 = ff12 + cff11; var cff12: int = ff12 / 256; ff12 = ff12 % 256
        ff13 = ff13 + cff12; var cff13: int = ff13 / 256; ff13 = ff13 % 256
        ff14 = ff14 + cff13; var cff14: int = ff14 / 256; ff14 = ff14 % 256
        ff15 = ff15 + cff14; var cff15: int = ff15 / 256; ff15 = ff15 % 256
        ff16 = ff16 + cff15; ff16 = ff16 % 256

        var acc0fb:  byte = ff0  as byte; var acc1fb:  byte = ff1  as byte
        var acc2fb:  byte = ff2  as byte; var acc3fb:  byte = ff3  as byte
        var acc4fb:  byte = ff4  as byte; var acc5fb:  byte = ff5  as byte
        var acc6fb:  byte = ff6  as byte; var acc7fb:  byte = ff7  as byte
        var acc8fb:  byte = ff8  as byte; var acc9fb:  byte = ff9  as byte
        var acc10fb: byte = ff10 as byte; var acc11fb: byte = ff11 as byte
        var acc12fb: byte = ff12 as byte; var acc13fb: byte = ff13 as byte
        var acc14fb: byte = ff14 as byte; var acc15fb: byte = ff15 as byte
        var acc16fb: byte = ff16 as byte
        this.acc[0]  = acc0fb;  this.acc[1]  = acc1fb
        this.acc[2]  = acc2fb;  this.acc[3]  = acc3fb
        this.acc[4]  = acc4fb;  this.acc[5]  = acc5fb
        this.acc[6]  = acc6fb;  this.acc[7]  = acc7fb
        this.acc[8]  = acc8fb;  this.acc[9]  = acc9fb
        this.acc[10] = acc10fb; this.acc[11] = acc11fb
        this.acc[12] = acc12fb; this.acc[13] = acc13fb
        this.acc[14] = acc14fb; this.acc[15] = acc15fb
        this.acc[16] = acc16fb
    }

    // FinalizeTag: compute tag = (acc + s) mod 2^128 and store in this.tag.
    // Must be called after all ProcessBlock calls.
    public fn FinalizeTag()
    {
        // Read acc.
        var a0:  int = this.acc[0]  as int
        var a1:  int = this.acc[1]  as int
        var a2:  int = this.acc[2]  as int
        var a3:  int = this.acc[3]  as int
        var a4:  int = this.acc[4]  as int
        var a5:  int = this.acc[5]  as int
        var a6:  int = this.acc[6]  as int
        var a7:  int = this.acc[7]  as int
        var a8:  int = this.acc[8]  as int
        var a9:  int = this.acc[9]  as int
        var a10: int = this.acc[10] as int
        var a11: int = this.acc[11] as int
        var a12: int = this.acc[12] as int
        var a13: int = this.acc[13] as int
        var a14: int = this.acc[14] as int
        var a15: int = this.acc[15] as int
        var a16: int = this.acc[16] as int

        // Final reduction: if acc >= 2^130-5, subtract (2^130-5).
        // 2^130-5 = 0x3fffffffffffffffffffffffffffffffb (130 bits).
        // In LE bytes: [0xfb, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff,
        //               0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0x03]
        // We compute acc + 5 and check if it overflows 2^130 (carry into bit 130).
        // If it does, acc >= 2^130-5, so we use the overflow value (acc + 5 mod 2^130).
        var t0:  int = a0  + 5
        var tc0: int = t0  / 256; t0  = t0  % 256
        var t1:  int = a1  + tc0; var tc1: int = t1  / 256; t1  = t1  % 256
        var t2:  int = a2  + tc1; var tc2: int = t2  / 256; t2  = t2  % 256
        var t3:  int = a3  + tc2; var tc3: int = t3  / 256; t3  = t3  % 256
        var t4:  int = a4  + tc3; var tc4: int = t4  / 256; t4  = t4  % 256
        var t5:  int = a5  + tc4; var tc5: int = t5  / 256; t5  = t5  % 256
        var t6:  int = a6  + tc5; var tc6: int = t6  / 256; t6  = t6  % 256
        var t7:  int = a7  + tc6; var tc7: int = t7  / 256; t7  = t7  % 256
        var t8:  int = a8  + tc7; var tc8: int = t8  / 256; t8  = t8  % 256
        var t9:  int = a9  + tc8; var tc9: int = t9  / 256; t9  = t9  % 256
        var t10: int = a10 + tc9; var tc10: int = t10 / 256; t10 = t10 % 256
        var t11: int = a11 + tc10; var tc11: int = t11 / 256; t11 = t11 % 256
        var t12: int = a12 + tc11; var tc12: int = t12 / 256; t12 = t12 % 256
        var t13: int = a13 + tc12; var tc13: int = t13 / 256; t13 = t13 % 256
        var t14: int = a14 + tc13; var tc14: int = t14 / 256; t14 = t14 % 256
        var t15: int = a15 + tc14; var tc15: int = t15 / 256; t15 = t15 % 256
        var t16: int = a16 + tc15; var tc16: int = t16 / 4;  t16 = t16 % 4

        // If tc16 > 0, then acc + 5 >= 2^130, meaning acc >= 2^130-5.
        // Use t[0..15] as the reduced accumulator (the +5 already accounts for subtraction).
        // Otherwise use a[0..15].
        // Conditional select without if: use mask.
        // mask = 0 if tc16==0, mask = 255 if tc16 > 0.
        // In Livt we can use arithmetic: if tc16 > 0 use t, else use a.
        // We can't use ternary, but we can compute:
        //   mask = (tc16 + 255) / 256  (0 when tc16=0, 1 when tc16=1..255)
        // Then: result = a * (1-mask) + t * mask
        // But multiplication is available. mask * 255 for AND-like behavior:
        //   result[i] = (a[i] * (1 - mask)) + (t[i] * mask)
        var mask: int = (tc16 + 255) / 256
        var inv:  int = 1 - mask

        var r0v: int = a0  * inv + t0  * mask
        var r1v: int = a1  * inv + t1  * mask
        var r2v: int = a2  * inv + t2  * mask
        var r3v: int = a3  * inv + t3  * mask
        var r4v: int = a4  * inv + t4  * mask
        var r5v: int = a5  * inv + t5  * mask
        var r6v: int = a6  * inv + t6  * mask
        var r7v: int = a7  * inv + t7  * mask
        var r8v: int = a8  * inv + t8  * mask
        var r9v: int = a9  * inv + t9  * mask
        var r10v: int = a10 * inv + t10 * mask
        var r11v: int = a11 * inv + t11 * mask
        var r12v: int = a12 * inv + t12 * mask
        var r13v: int = a13 * inv + t13 * mask
        var r14v: int = a14 * inv + t14 * mask
        var r15v: int = a15 * inv + t15 * mask

        // Add s (mod 2^128).
        var s0i:  int = this.s[0]  as int
        var s1i:  int = this.s[1]  as int
        var s2i:  int = this.s[2]  as int
        var s3i:  int = this.s[3]  as int
        var s4i:  int = this.s[4]  as int
        var s5i:  int = this.s[5]  as int
        var s6i:  int = this.s[6]  as int
        var s7i:  int = this.s[7]  as int
        var s8i:  int = this.s[8]  as int
        var s9i:  int = this.s[9]  as int
        var s10i: int = this.s[10] as int
        var s11i: int = this.s[11] as int
        var s12i: int = this.s[12] as int
        var s13i: int = this.s[13] as int
        var s14i: int = this.s[14] as int
        var s15i: int = this.s[15] as int

        var u0:  int = r0v  + s0i;  var cu0:  int = u0  / 256; u0  = u0  % 256
        var u1:  int = r1v  + s1i  + cu0;  var cu1:  int = u1  / 256; u1  = u1  % 256
        var u2:  int = r2v  + s2i  + cu1;  var cu2:  int = u2  / 256; u2  = u2  % 256
        var u3:  int = r3v  + s3i  + cu2;  var cu3:  int = u3  / 256; u3  = u3  % 256
        var u4:  int = r4v  + s4i  + cu3;  var cu4:  int = u4  / 256; u4  = u4  % 256
        var u5:  int = r5v  + s5i  + cu4;  var cu5:  int = u5  / 256; u5  = u5  % 256
        var u6:  int = r6v  + s6i  + cu5;  var cu6:  int = u6  / 256; u6  = u6  % 256
        var u7:  int = r7v  + s7i  + cu6;  var cu7:  int = u7  / 256; u7  = u7  % 256
        var u8:  int = r8v  + s8i  + cu7;  var cu8:  int = u8  / 256; u8  = u8  % 256
        var u9:  int = r9v  + s9i  + cu8;  var cu9:  int = u9  / 256; u9  = u9  % 256
        var u10: int = r10v + s10i + cu9;  var cu10: int = u10 / 256; u10 = u10 % 256
        var u11: int = r11v + s11i + cu10; var cu11: int = u11 / 256; u11 = u11 % 256
        var u12: int = r12v + s12i + cu11; var cu12: int = u12 / 256; u12 = u12 % 256
        var u13: int = r13v + s13i + cu12; var cu13: int = u13 / 256; u13 = u13 % 256
        var u14: int = r14v + s14i + cu13; var cu14: int = u14 / 256; u14 = u14 % 256
        var u15: int = r15v + s15i + cu14; u15 = u15 % 256

        // Store tag (low 128 bits = 16 bytes, via local byte vars per §10).
        var tg0:  byte = u0  as byte; var tg1:  byte = u1  as byte
        var tg2:  byte = u2  as byte; var tg3:  byte = u3  as byte
        var tg4:  byte = u4  as byte; var tg5:  byte = u5  as byte
        var tg6:  byte = u6  as byte; var tg7:  byte = u7  as byte
        var tg8:  byte = u8  as byte; var tg9:  byte = u9  as byte
        var tg10: byte = u10 as byte; var tg11: byte = u11 as byte
        var tg12: byte = u12 as byte; var tg13: byte = u13 as byte
        var tg14: byte = u14 as byte; var tg15: byte = u15 as byte
        this.tag[0]  = tg0;  this.tag[1]  = tg1
        this.tag[2]  = tg2;  this.tag[3]  = tg3
        this.tag[4]  = tg4;  this.tag[5]  = tg5
        this.tag[6]  = tg6;  this.tag[7]  = tg7
        this.tag[8]  = tg8;  this.tag[9]  = tg9
        this.tag[10] = tg10; this.tag[11] = tg11
        this.tag[12] = tg12; this.tag[13] = tg13
        this.tag[14] = tg14; this.tag[15] = tg15
    }

    public fn GetTag() byte[16]
    {
        return this.tag
    }

    public fn GetByte(idx: int) byte
    {
        return this.tag[idx]
    }
}
