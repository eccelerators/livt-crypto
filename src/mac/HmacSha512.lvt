        this.kIpad[83]  = 0x36; this.kOpad[83]  = 0x5c
        this.kIpad[84]  = 0x36; this.kOpad[84]  = 0x5c
        this.kIpad[85]  = 0x36; this.kOpad[85]  = 0x5c
        this.kIpad[86]  = 0x36; this.kOpad[86]  = 0x5c
        this.kIpad[87]  = 0x36; this.kOpad[87]  = 0x5c
