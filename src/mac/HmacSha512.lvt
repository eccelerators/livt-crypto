        this.kIpad[96]  = 0x36; this.kOpad[96]  = 0x5c
        this.kIpad[97]  = 0x36; this.kOpad[97]  = 0x5c
        this.kIpad[98]  = 0x36; this.kOpad[98]  = 0x5c
        this.kIpad[99]  = 0x36; this.kOpad[99]  = 0x5c
        this.kIpad[100] = 0x36; this.kOpad[100] = 0x5c
