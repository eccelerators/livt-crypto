namespace Livt.Crypto.Mac
using Livt.Crypto.Hash


// HMAC-SHA-512 (RFC 2104 + NIST FIPS 180-4) — single-block message model.
//
// Usage (per message):
//   1. SetKey(key)                 — derive k_ipad / k_opad blocks from 64-byte key
//      (key is zero-padded to the 128-byte block size internally)
//   2. Init()                      — Reset inner SHA and process k_ipad block
//   3. ProcessBlock(block)         — feed each additional 128-byte message block
//      Caller is responsible for SHA-512 padding of the last message block,
//      accounting for the 128-byte k_ipad prefix already consumed in Init().
//      Total inner length = 128 + |message_bytes|.
//   4. GetHmac() byte[64]          — finalise inner hash and run outer pass
//
// Key length convention: KEY_SIZE = 64 (= DIGEST_SIZE).  Keys ≤ 64 bytes are
// zero-padded to 128 bytes (BLOCK_SIZE) by SetKey.  Keys > 64 bytes should be
// SHA-512-hashed by the caller before passing to SetKey.
component HmacSha512
{
    public const KEY_SIZE:    int = 64
    public const BLOCK_SIZE:  int = 128
    public const DIGEST_SIZE: int = 64

    sha:   Sha512
    kIpad: byte[128]
    kOpad: byte[128]

    new()
    {
        this.sha = new Sha512()
    }

    // -----------------------------------------------------------------------
    // Public API
    // -----------------------------------------------------------------------

    // SetKey pads key to BLOCK_SIZE bytes then XORs with ipad (0x36) and
    // opad (0x5c) to produce the two keyed-block constants.
    public fn SetKey(key: byte[64])
    {
        // Bytes 0-63: XOR key byte with pad constants.
        var ip0:  byte = key[0] ^ 0x36; var op0:  byte = key[0] ^ 0x5c
        var ip1:  byte = key[1] ^ 0x36; var op1:  byte = key[1] ^ 0x5c
        var ip2:  byte = key[2] ^ 0x36; var op2:  byte = key[2] ^ 0x5c
        var ip3:  byte = key[3] ^ 0x36; var op3:  byte = key[3] ^ 0x5c
        var ip4:  byte = key[4] ^ 0x36; var op4:  byte = key[4] ^ 0x5c
        var ip5:  byte = key[5] ^ 0x36; var op5:  byte = key[5] ^ 0x5c
        var ip6:  byte = key[6] ^ 0x36; var op6:  byte = key[6] ^ 0x5c
        var ip7:  byte = key[7] ^ 0x36; var op7:  byte = key[7] ^ 0x5c
        var ip8:  byte = key[8] ^ 0x36; var op8:  byte = key[8] ^ 0x5c
        var ip9:  byte = key[9] ^ 0x36; var op9:  byte = key[9] ^ 0x5c
        var ip10: byte = key[10] ^ 0x36; var op10: byte = key[10] ^ 0x5c
        var ip11: byte = key[11] ^ 0x36; var op11: byte = key[11] ^ 0x5c
        var ip12: byte = key[12] ^ 0x36; var op12: byte = key[12] ^ 0x5c
        var ip13: byte = key[13] ^ 0x36; var op13: byte = key[13] ^ 0x5c
        var ip14: byte = key[14] ^ 0x36; var op14: byte = key[14] ^ 0x5c
        var ip15: byte = key[15] ^ 0x36; var op15: byte = key[15] ^ 0x5c
        var ip16: byte = key[16] ^ 0x36; var op16: byte = key[16] ^ 0x5c
        var ip17: byte = key[17] ^ 0x36; var op17: byte = key[17] ^ 0x5c
        var ip18: byte = key[18] ^ 0x36; var op18: byte = key[18] ^ 0x5c
        var ip19: byte = key[19] ^ 0x36; var op19: byte = key[19] ^ 0x5c
        var ip20: byte = key[20] ^ 0x36; var op20: byte = key[20] ^ 0x5c
        var ip21: byte = key[21] ^ 0x36; var op21: byte = key[21] ^ 0x5c
        var ip22: byte = key[22] ^ 0x36; var op22: byte = key[22] ^ 0x5c
        var ip23: byte = key[23] ^ 0x36; var op23: byte = key[23] ^ 0x5c
        var ip24: byte = key[24] ^ 0x36; var op24: byte = key[24] ^ 0x5c
        var ip25: byte = key[25] ^ 0x36; var op25: byte = key[25] ^ 0x5c
        var ip26: byte = key[26] ^ 0x36; var op26: byte = key[26] ^ 0x5c
        var ip27: byte = key[27] ^ 0x36; var op27: byte = key[27] ^ 0x5c
        var ip28: byte = key[28] ^ 0x36; var op28: byte = key[28] ^ 0x5c
        var ip29: byte = key[29] ^ 0x36; var op29: byte = key[29] ^ 0x5c
        var ip30: byte = key[30] ^ 0x36; var op30: byte = key[30] ^ 0x5c
        var ip31: byte = key[31] ^ 0x36; var op31: byte = key[31] ^ 0x5c
        var ip32: byte = key[32] ^ 0x36; var op32: byte = key[32] ^ 0x5c
        var ip33: byte = key[33] ^ 0x36; var op33: byte = key[33] ^ 0x5c
        var ip34: byte = key[34] ^ 0x36; var op34: byte = key[34] ^ 0x5c
        var ip35: byte = key[35] ^ 0x36; var op35: byte = key[35] ^ 0x5c
        var ip36: byte = key[36] ^ 0x36; var op36: byte = key[36] ^ 0x5c
        var ip37: byte = key[37] ^ 0x36; var op37: byte = key[37] ^ 0x5c
        var ip38: byte = key[38] ^ 0x36; var op38: byte = key[38] ^ 0x5c
        var ip39: byte = key[39] ^ 0x36; var op39: byte = key[39] ^ 0x5c
        var ip40: byte = key[40] ^ 0x36; var op40: byte = key[40] ^ 0x5c
        var ip41: byte = key[41] ^ 0x36; var op41: byte = key[41] ^ 0x5c
        var ip42: byte = key[42] ^ 0x36; var op42: byte = key[42] ^ 0x5c
        var ip43: byte = key[43] ^ 0x36; var op43: byte = key[43] ^ 0x5c
        var ip44: byte = key[44] ^ 0x36; var op44: byte = key[44] ^ 0x5c
        var ip45: byte = key[45] ^ 0x36; var op45: byte = key[45] ^ 0x5c
        var ip46: byte = key[46] ^ 0x36; var op46: byte = key[46] ^ 0x5c
        var ip47: byte = key[47] ^ 0x36; var op47: byte = key[47] ^ 0x5c
        var ip48: byte = key[48] ^ 0x36; var op48: byte = key[48] ^ 0x5c
        var ip49: byte = key[49] ^ 0x36; var op49: byte = key[49] ^ 0x5c
        var ip50: byte = key[50] ^ 0x36; var op50: byte = key[50] ^ 0x5c
        var ip51: byte = key[51] ^ 0x36; var op51: byte = key[51] ^ 0x5c
        var ip52: byte = key[52] ^ 0x36; var op52: byte = key[52] ^ 0x5c
        var ip53: byte = key[53] ^ 0x36; var op53: byte = key[53] ^ 0x5c
        var ip54: byte = key[54] ^ 0x36; var op54: byte = key[54] ^ 0x5c
        var ip55: byte = key[55] ^ 0x36; var op55: byte = key[55] ^ 0x5c
        var ip56: byte = key[56] ^ 0x36; var op56: byte = key[56] ^ 0x5c
        var ip57: byte = key[57] ^ 0x36; var op57: byte = key[57] ^ 0x5c
        var ip58: byte = key[58] ^ 0x36; var op58: byte = key[58] ^ 0x5c
        var ip59: byte = key[59] ^ 0x36; var op59: byte = key[59] ^ 0x5c
        var ip60: byte = key[60] ^ 0x36; var op60: byte = key[60] ^ 0x5c
        var ip61: byte = key[61] ^ 0x36; var op61: byte = key[61] ^ 0x5c
        var ip62: byte = key[62] ^ 0x36; var op62: byte = key[62] ^ 0x5c
        var ip63: byte = key[63] ^ 0x36; var op63: byte = key[63] ^ 0x5c

        this.kIpad[0]  = ip0;  this.kOpad[0]  = op0
        this.kIpad[1]  = ip1;  this.kOpad[1]  = op1
        this.kIpad[2]  = ip2;  this.kOpad[2]  = op2
        this.kIpad[3]  = ip3;  this.kOpad[3]  = op3
        this.kIpad[4]  = ip4;  this.kOpad[4]  = op4
        this.kIpad[5]  = ip5;  this.kOpad[5]  = op5
        this.kIpad[6]  = ip6;  this.kOpad[6]  = op6
        this.kIpad[7]  = ip7;  this.kOpad[7]  = op7
        this.kIpad[8]  = ip8;  this.kOpad[8]  = op8
        this.kIpad[9]  = ip9;  this.kOpad[9]  = op9
        this.kIpad[10] = ip10; this.kOpad[10] = op10
        this.kIpad[11] = ip11; this.kOpad[11] = op11
        this.kIpad[12] = ip12; this.kOpad[12] = op12
        this.kIpad[13] = ip13; this.kOpad[13] = op13
        this.kIpad[14] = ip14; this.kOpad[14] = op14
        this.kIpad[15] = ip15; this.kOpad[15] = op15
        this.kIpad[16] = ip16; this.kOpad[16] = op16
        this.kIpad[17] = ip17; this.kOpad[17] = op17
        this.kIpad[18] = ip18; this.kOpad[18] = op18
        this.kIpad[19] = ip19; this.kOpad[19] = op19
        this.kIpad[20] = ip20; this.kOpad[20] = op20
        this.kIpad[21] = ip21; this.kOpad[21] = op21
        this.kIpad[22] = ip22; this.kOpad[22] = op22
        this.kIpad[23] = ip23; this.kOpad[23] = op23
        this.kIpad[24] = ip24; this.kOpad[24] = op24
        this.kIpad[25] = ip25; this.kOpad[25] = op25
        this.kIpad[26] = ip26; this.kOpad[26] = op26
        this.kIpad[27] = ip27; this.kOpad[27] = op27
        this.kIpad[28] = ip28; this.kOpad[28] = op28
        this.kIpad[29] = ip29; this.kOpad[29] = op29
        this.kIpad[30] = ip30; this.kOpad[30] = op30
        this.kIpad[31] = ip31; this.kOpad[31] = op31
        this.kIpad[32] = ip32; this.kOpad[32] = op32
        this.kIpad[33] = ip33; this.kOpad[33] = op33
        this.kIpad[34] = ip34; this.kOpad[34] = op34
        this.kIpad[35] = ip35; this.kOpad[35] = op35
        this.kIpad[36] = ip36; this.kOpad[36] = op36
        this.kIpad[37] = ip37; this.kOpad[37] = op37
        this.kIpad[38] = ip38; this.kOpad[38] = op38
        this.kIpad[39] = ip39; this.kOpad[39] = op39
        this.kIpad[40] = ip40; this.kOpad[40] = op40
        this.kIpad[41] = ip41; this.kOpad[41] = op41
        this.kIpad[42] = ip42; this.kOpad[42] = op42
        this.kIpad[43] = ip43; this.kOpad[43] = op43
        this.kIpad[44] = ip44; this.kOpad[44] = op44
        this.kIpad[45] = ip45; this.kOpad[45] = op45
        this.kIpad[46] = ip46; this.kOpad[46] = op46
        this.kIpad[47] = ip47; this.kOpad[47] = op47
        this.kIpad[48] = ip48; this.kOpad[48] = op48
        this.kIpad[49] = ip49; this.kOpad[49] = op49
        this.kIpad[50] = ip50; this.kOpad[50] = op50
        this.kIpad[51] = ip51; this.kOpad[51] = op51
        this.kIpad[52] = ip52; this.kOpad[52] = op52
        this.kIpad[53] = ip53; this.kOpad[53] = op53
        this.kIpad[54] = ip54; this.kOpad[54] = op54
        this.kIpad[55] = ip55; this.kOpad[55] = op55
        this.kIpad[56] = ip56; this.kOpad[56] = op56
        this.kIpad[57] = ip57; this.kOpad[57] = op57
        this.kIpad[58] = ip58; this.kOpad[58] = op58
        this.kIpad[59] = ip59; this.kOpad[59] = op59
        this.kIpad[60] = ip60; this.kOpad[60] = op60
        this.kIpad[61] = ip61; this.kOpad[61] = op61
        this.kIpad[62] = ip62; this.kOpad[62] = op62
        this.kIpad[63] = ip63; this.kOpad[63] = op63

        // Bytes 64-127: zero-padded key XOR pad = constant.
        this.kIpad[64]  = 0x36; this.kOpad[64]  = 0x5c
        this.kIpad[65]  = 0x36; this.kOpad[65]  = 0x5c
        this.kIpad[66]  = 0x36; this.kOpad[66]  = 0x5c
        this.kIpad[67]  = 0x36; this.kOpad[67]  = 0x5c
        this.kIpad[68]  = 0x36; this.kOpad[68]  = 0x5c
        this.kIpad[69]  = 0x36; this.kOpad[69]  = 0x5c
        this.kIpad[70]  = 0x36; this.kOpad[70]  = 0x5c
        this.kIpad[71]  = 0x36; this.kOpad[71]  = 0x5c
        this.kIpad[72]  = 0x36; this.kOpad[72]  = 0x5c
        this.kIpad[73]  = 0x36; this.kOpad[73]  = 0x5c
        this.kIpad[74]  = 0x36; this.kOpad[74]  = 0x5c
        this.kIpad[75]  = 0x36; this.kOpad[75]  = 0x5c
        this.kIpad[76]  = 0x36; this.kOpad[76]  = 0x5c
        this.kIpad[77]  = 0x36; this.kOpad[77]  = 0x5c
