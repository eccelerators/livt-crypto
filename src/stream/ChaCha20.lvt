        var ks16b: byte = f4[0] as byte; var ks17b: byte = f4[1] as byte; var ks18b: byte = f4[2] as byte; var ks19b: byte = f4[3] as byte
        var ks20b: byte = f5[0] as byte; var ks21b: byte = f5[1] as byte; var ks22b: byte = f5[2] as byte; var ks23b: byte = f5[3] as byte
        var ks24b: byte = f6[0] as byte; var ks25b: byte = f6[1] as byte; var ks26b: byte = f6[2] as byte; var ks27b: byte = f6[3] as byte
        var ks28b: byte = f7[0] as byte; var ks29b: byte = f7[1] as byte; var ks30b: byte = f7[2] as byte; var ks31b: byte = f7[3] as byte
        var ks32b: byte = f8[0] as byte; var ks33b: byte = f8[1] as byte; var ks34b: byte = f8[2] as byte; var ks35b: byte = f8[3] as byte
        var ks36b: byte = f9[0] as byte; var ks37b: byte = f9[1] as byte; var ks38b: byte = f9[2] as byte; var ks39b: byte = f9[3] as byte
        var ks40b: byte = f10[0] as byte; var ks41b: byte = f10[1] as byte; var ks42b: byte = f10[2] as byte; var ks43b: byte = f10[3] as byte
        var ks44b: byte = f11[0] as byte; var ks45b: byte = f11[1] as byte; var ks46b: byte = f11[2] as byte; var ks47b: byte = f11[3] as byte
        var ks48b: byte = f12[0] as byte; var ks49b: byte = f12[1] as byte; var ks50b: byte = f12[2] as byte; var ks51b: byte = f12[3] as byte
        var ks52b: byte = f13[0] as byte; var ks53b: byte = f13[1] as byte; var ks54b: byte = f13[2] as byte; var ks55b: byte = f13[3] as byte
        var ks56b: byte = f14[0] as byte; var ks57b: byte = f14[1] as byte; var ks58b: byte = f14[2] as byte; var ks59b: byte = f14[3] as byte
        var ks60b: byte = f15[0] as byte; var ks61b: byte = f15[1] as byte; var ks62b: byte = f15[2] as byte; var ks63b: byte = f15[3] as byte

        this.outBlk[0]  = p0 ^ ks0b;  this.outBlk[1]  = p1 ^ ks1b
        this.outBlk[2]  = p2 ^ ks2b;  this.outBlk[3]  = p3 ^ ks3b
        this.outBlk[4]  = p4 ^ ks4b;  this.outBlk[5]  = p5 ^ ks5b
        this.outBlk[6]  = p6 ^ ks6b;  this.outBlk[7]  = p7 ^ ks7b
        this.outBlk[8]  = p8 ^ ks8b;  this.outBlk[9]  = p9 ^ ks9b
        this.outBlk[10] = p10 ^ ks10b; this.outBlk[11] = p11 ^ ks11b
        this.outBlk[12] = p12 ^ ks12b; this.outBlk[13] = p13 ^ ks13b
        this.outBlk[14] = p14 ^ ks14b; this.outBlk[15] = p15 ^ ks15b
        this.outBlk[16] = p16 ^ ks16b; this.outBlk[17] = p17 ^ ks17b
        this.outBlk[18] = p18 ^ ks18b; this.outBlk[19] = p19 ^ ks19b
        this.outBlk[20] = p20 ^ ks20b; this.outBlk[21] = p21 ^ ks21b
        this.outBlk[22] = p22 ^ ks22b; this.outBlk[23] = p23 ^ ks23b
        this.outBlk[24] = p24 ^ ks24b; this.outBlk[25] = p25 ^ ks25b
        this.outBlk[26] = p26 ^ ks26b; this.outBlk[27] = p27 ^ ks27b
        this.outBlk[28] = p28 ^ ks28b; this.outBlk[29] = p29 ^ ks29b
        this.outBlk[30] = p30 ^ ks30b; this.outBlk[31] = p31 ^ ks31b
        this.outBlk[32] = p32 ^ ks32b; this.outBlk[33] = p33 ^ ks33b
        this.outBlk[34] = p34 ^ ks34b; this.outBlk[35] = p35 ^ ks35b
        this.outBlk[36] = p36 ^ ks36b; this.outBlk[37] = p37 ^ ks37b
        this.outBlk[38] = p38 ^ ks38b; this.outBlk[39] = p39 ^ ks39b
        this.outBlk[40] = p40 ^ ks40b; this.outBlk[41] = p41 ^ ks41b
        this.outBlk[42] = p42 ^ ks42b; this.outBlk[43] = p43 ^ ks43b
        this.outBlk[44] = p44 ^ ks44b; this.outBlk[45] = p45 ^ ks45b
        this.outBlk[46] = p46 ^ ks46b; this.outBlk[47] = p47 ^ ks47b
        this.outBlk[48] = p48 ^ ks48b; this.outBlk[49] = p49 ^ ks49b
        this.outBlk[50] = p50 ^ ks50b; this.outBlk[51] = p51 ^ ks51b
        this.outBlk[52] = p52 ^ ks52b; this.outBlk[53] = p53 ^ ks53b
        this.outBlk[54] = p54 ^ ks54b; this.outBlk[55] = p55 ^ ks55b
        this.outBlk[56] = p56 ^ ks56b; this.outBlk[57] = p57 ^ ks57b
        this.outBlk[58] = p58 ^ ks58b; this.outBlk[59] = p59 ^ ks59b
        this.outBlk[60] = p60 ^ ks60b; this.outBlk[61] = p61 ^ ks61b
        this.outBlk[62] = p62 ^ ks62b; this.outBlk[63] = p63 ^ ks63b

        // Increment the 32-bit counter (little-endian).
        this.IncrementCounter()
    }

    public fn GetBlock() byte[64]
    {
        return this.outBlk
    }

    public fn GetByte(idx: int) byte
    {
        return this.outBlk[idx]
    }

    public fn ClearKey()
    {
        for (var i = 0; i < 32; i++)
        {
            this.key[i] = 0x00
        }
    }

    // -----------------------------------------------------------------------
    // Private helpers
    // -----------------------------------------------------------------------

    // QR: ChaCha20 quarter-round on four 32-bit little-endian words.
    // Each word is passed as 4 ints (LS byte first: wa, wb, wc, wd).
    // Returns 16 ints: new a (4), new b (4), new c (4), new d (4).
    fn QR[](aa: int, ab: int, ac: int, ad: int,
          ba: int, bb: int, bc: int, bd: int,
          ca: int, cb: int, cc: int, cd: int,
          da: int, db: int, dc: int, dd: int) int[16]
    {
        // a += b
        var add1: int[4] = this.AddWord32(aa, ab, ac, ad, ba, bb, bc, bd)
        var na0: int = add1[0]; var na1: int = add1[1]; var na2: int = add1[2]; var na3: int = add1[3]
        // d ^= a
        var xd: int[4] = this.XorWord32(da, db, dc, dd, na0, na1, na2, na3)
        var nd0: int = xd[0]; var nd1: int = xd[1]; var nd2: int = xd[2]; var nd3: int = xd[3]
        // d = d <<< 16
        var rd16: int[4] = this.Rotl16(nd0, nd1, nd2, nd3)
        nd0 = rd16[0]; nd1 = rd16[1]; nd2 = rd16[2]; nd3 = rd16[3]

        // c += d
        var add2: int[4] = this.AddWord32(ca, cb, cc, cd, nd0, nd1, nd2, nd3)
        var nc0: int = add2[0]; var nc1: int = add2[1]; var nc2: int = add2[2]; var nc3: int = add2[3]
        // b ^= c
        var xb: int[4] = this.XorWord32(ba, bb, bc, bd, nc0, nc1, nc2, nc3)
        var nb0: int = xb[0]; var nb1: int = xb[1]; var nb2: int = xb[2]; var nb3: int = xb[3]
        // b = b <<< 12
        var rb12: int[4] = this.Rotl12(nb0, nb1, nb2, nb3)
        nb0 = rb12[0]; nb1 = rb12[1]; nb2 = rb12[2]; nb3 = rb12[3]

        // a += b
        var add3: int[4] = this.AddWord32(na0, na1, na2, na3, nb0, nb1, nb2, nb3)
        na0 = add3[0]; na1 = add3[1]; na2 = add3[2]; na3 = add3[3]
        // d ^= a
        var xd2: int[4] = this.XorWord32(nd0, nd1, nd2, nd3, na0, na1, na2, na3)
        nd0 = xd2[0]; nd1 = xd2[1]; nd2 = xd2[2]; nd3 = xd2[3]
        // d = d <<< 8
        var rd8: int[4] = this.Rotl8(nd0, nd1, nd2, nd3)
        nd0 = rd8[0]; nd1 = rd8[1]; nd2 = rd8[2]; nd3 = rd8[3]

        // c += d
        var add4: int[4] = this.AddWord32(nc0, nc1, nc2, nc3, nd0, nd1, nd2, nd3)
        nc0 = add4[0]; nc1 = add4[1]; nc2 = add4[2]; nc3 = add4[3]
        // b ^= c
        var xb2: int[4] = this.XorWord32(nb0, nb1, nb2, nb3, nc0, nc1, nc2, nc3)
        nb0 = xb2[0]; nb1 = xb2[1]; nb2 = xb2[2]; nb3 = xb2[3]
        // b = b <<< 7
        var rb7: int[4] = this.Rotl7(nb0, nb1, nb2, nb3)
        nb0 = rb7[0]; nb1 = rb7[1]; nb2 = rb7[2]; nb3 = rb7[3]

        var result: int[16]
        result[0]  = na0; result[1]  = na1; result[2]  = na2; result[3]  = na3
        result[4]  = nb0; result[5]  = nb1; result[6]  = nb2; result[7]  = nb3
        result[8]  = nc0; result[9]  = nc1; result[10] = nc2; result[11] = nc3
        result[12] = nd0; result[13] = nd1; result[14] = nd2; result[15] = nd3
        return result
    }

    // AddWord32: modular 32-bit addition, little-endian (LS byte first).
    inline fn AddWord32[](a0: int, a1: int, a2: int, a3: int,
                 b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var s0: int = a0 + b0
        var c0: int = s0 / 256
        var r0: int = s0 % 256
        var s1: int = a1 + b1 + c0
        var c1: int = s1 / 256
        var r1: int = s1 % 256
        var s2: int = a2 + b2 + c1
        var c2: int = s2 / 256
        var r2: int = s2 % 256
        var s3: int = a3 + b3 + c2
        var r3: int = s3 % 256
        var result: int[4]
        result[0] = r0
        result[1] = r1
        result[2] = r2
        result[3] = r3
        return result
    }

    // XorWord32: bitwise XOR of two 32-bit little-endian words (byte-by-byte).
    inline fn XorWord32[](a0: int, a1: int, a2: int, a3: int,
                 b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var xa: byte = a0 as byte; var xb: byte = b0 as byte; var x0b: byte = xa ^ xb; var x0: int = x0b as int
        var ya: byte = a1 as byte; var yb: byte = b1 as byte; var x1b: byte = ya ^ yb; var x1: int = x1b as int
        var za: byte = a2 as byte; var zb: byte = b2 as byte; var x2b: byte = za ^ zb; var x2: int = x2b as int
        var wa: byte = a3 as byte; var wb: byte = b3 as byte; var x3b: byte = wa ^ wb; var x3: int = x3b as int
        var result: int[4]
        result[0] = x0
        result[1] = x1
        result[2] = x2
        result[3] = x3
        return result
    }

    // Rotl16: rotate left 32-bit little-endian word by 16 bits.
    // LE bytes [b0,b1,b2,b3] represent value b0 + b1*256 + b2*65536 + b3*16777216.
    // Rotl16 swaps the two 16-bit halves: result = (val >> 16) | (val << 16) mod 2^32.
    // In byte terms: [b2, b3, b0, b1].
    inline fn Rotl16[](b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var result: int[4]
        result[0] = b2
        result[1] = b3
        result[2] = b0
        result[3] = b1
        return result
    }

    // Rotl8: rotate left 32-bit little-endian word by 8 bits.
    // In byte terms: [b3, b0, b1, b2].
    inline fn Rotl8[](b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var result: int[4]
        result[0] = b3
        result[1] = b0
        result[2] = b1
        result[3] = b2
        return result
    }

    // Rotl12: rotate left 32-bit little-endian word by 12 bits.
    // 12 bits = 1 byte + 4 bits.
    // val' = (val << 12) | (val >> 20) mod 2^32.
    // b0' = (b2 >> 4) | (b3 << 4)  [byte 0 of result]
    // b1' = (b3 >> 4) | (b0 << 4)
    // b2' = (b0 >> 4) | (b1 << 4)
    // b3' = (b1 >> 4) | (b2 << 4)
    inline fn Rotl12[](b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var r0: int = (b2 / 16) + (b3 % 16) * 16
        var r1: int = (b3 / 16) + (b0 % 16) * 16
        var r2: int = (b0 / 16) + (b1 % 16) * 16
        var r3: int = (b1 / 16) + (b2 % 16) * 16
        var result: int[4]
        result[0] = r0
        result[1] = r1
        result[2] = r2
        result[3] = r3
        return result
    }

    // Rotl7: rotate left 32-bit little-endian word by 7 bits.
    // val' = (val << 7) | (val >> 25) mod 2^32.
    // b0' = (b3 >> 1) | (b0 << 7) [only low bit of b0]
    //      = (b3 / 2) + (b0 % 2) * 128
    // b1' = (b0 >> 1) + (b1 % 2) * 128
    // b2' = (b1 >> 1) + (b2 % 2) * 128
    // b3' = (b2 >> 1) + (b3 % 2) * 128
    inline fn Rotl7[](b0: int, b1: int, b2: int, b3: int) int[4]
    {
        var r0: int = (b3 / 2) + (b0 % 2) * 128
        var r1: int = (b0 / 2) + (b1 % 2) * 128
        var r2: int = (b1 / 2) + (b2 % 2) * 128
        var r3: int = (b2 / 2) + (b3 % 2) * 128
        var result: int[4]
        result[0] = r0
        result[1] = r1
        result[2] = r2
        result[3] = r3
        return result
    }

    // IncrementCounter: increment the 32-bit little-endian counter.
    fn IncrementCounter()
    {
        var c0: int = this.ctr0
        var c1: int = this.ctr1
        var c2: int = this.ctr2
        var c3: int = this.ctr3
        c0 = c0 + 1
        if (c0 == 256)
        {
            c0 = 0
            c1 = c1 + 1
            if (c1 == 256)
            {
                c1 = 0
                c2 = c2 + 1
                if (c2 == 256)
                {
                    c2 = 0
                    c3 = c3 + 1
                    if (c3 == 256)
                    {
                        c3 = 0
                    }
                }
            }
        }
        this.ctr0 = c0
        this.ctr1 = c1
        this.ctr2 = c2
        this.ctr3 = c3
    }
}
