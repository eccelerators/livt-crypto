namespace Livt.Crypto.Stream

// ChaCha20 stream cipher — single-block interface (RFC 8439).
// Produces one 64-byte keystream block from a 256-bit key, 32-bit counter,
// and 96-bit nonce, then XORs it with the input block.
//
// State layout (little-endian 32-bit words):
//   s0..s3  = "expa", "nd 3", "2-by", "te k"  (constants)
//   s4..s11 = key (8 × 32-bit LE words)
//   s12     = counter (32-bit LE)
//   s13..s15= nonce (3 × 32-bit LE words)
//
// Usage:
//   1. SetKey(key[32])
//   2. SetCounter(counter[16])  — bytes 0-11 nonce, bytes 12-15 counter (LE)
//   3. LoadBlock(block[64])
//   4. CryptBlock()
//   5. GetBlock() byte[64]     — ciphertext (or plaintext when decrypting)
component ChaCha20
{
    public const KEY_SIZE:   int = 32
    public const BLOCK_SIZE: int = 64
    public const NONCE_SIZE: int = 12

    // Key stored as 32 bytes (little-endian 32-bit word layout).
    key: byte[32]

    // Counter (little-endian 4 bytes) and nonce (little-endian 12 bytes).
    ctr0: int
    ctr1: int
    ctr2: int
    ctr3: int
    n0:  int
    n1:  int
    n2:  int
    n3:  int
    n4:  int
    n5:  int
    n6:  int
    n7:  int
    n8:  int
    n9:  int
    n10: int
    n11: int

    // Input plaintext / ciphertext block.
    blk: byte[64]

    // Output block.
    outBlk: byte[64]

    new()
    {
    }

    // -----------------------------------------------------------------------
    // Public API
    // -----------------------------------------------------------------------

    public fn SetKey(key: byte[32])
    {
        for (var i = 0; i < 32; i++)
        {
            this.key[i] = key[i]
        }
    }

    // SetCounter: bytes 0-11 = nonce, bytes 12-15 = 32-bit counter (little-endian).
    public fn SetCounter(counter: byte[16])
    {
        var bn0:  byte = counter[0];  var in0:  int = bn0  as int
        var bn1:  byte = counter[1];  var in1:  int = bn1  as int
        var bn2:  byte = counter[2];  var in2:  int = bn2  as int
        var bn3:  byte = counter[3];  var in3:  int = bn3  as int
        var bn4:  byte = counter[4];  var in4:  int = bn4  as int
        var bn5:  byte = counter[5];  var in5:  int = bn5  as int
        var bn6:  byte = counter[6];  var in6:  int = bn6  as int
        var bn7:  byte = counter[7];  var in7:  int = bn7  as int
        var bn8:  byte = counter[8];  var in8:  int = bn8  as int
        var bn9:  byte = counter[9];  var in9:  int = bn9  as int
        var bn10: byte = counter[10]; var in10: int = bn10 as int
        var bn11: byte = counter[11]; var in11: int = bn11 as int
        var bc0:  byte = counter[12]; var ic0:  int = bc0  as int
        var bc1:  byte = counter[13]; var ic1:  int = bc1  as int
        var bc2:  byte = counter[14]; var ic2:  int = bc2  as int
        var bc3:  byte = counter[15]; var ic3:  int = bc3  as int
        this.n0  = in0
        this.n1  = in1
        this.n2  = in2
        this.n3  = in3
        this.n4  = in4
        this.n5  = in5
        this.n6  = in6
        this.n7  = in7
        this.n8  = in8
        this.n9  = in9
        this.n10 = in10
        this.n11 = in11
        this.ctr0 = ic0
        this.ctr1 = ic1
        this.ctr2 = ic2
        this.ctr3 = ic3
    }

    public fn LoadBlock(blk: byte[64])
    {
        for (var i = 0; i < 64; i++)
        {
            this.blk[i] = blk[i]
        }
    }

    // CryptBlock: generate the 64-byte keystream block, XOR with the input,
    // store in outBlk, then increment the 32-bit counter (little-endian).
    public fn CryptBlock()
    {
        // ---------------------------------------------------------------
        // Build the initial state from constants, key, counter, and nonce.
        // All words are little-endian.
        // ---------------------------------------------------------------
        // State words s0..s15 stored as 4 bytes each: s_a (LS byte) .. s_d (MS byte).

        // s0..s3 = constants "expa" "nd 3" "2-by" "te k"
        var s0a: int = 0x65; var s0b: int = 0x78; var s0c: int = 0x70; var s0d: int = 0x61
        var s1a: int = 0x6e; var s1b: int = 0x64; var s1c: int = 0x20; var s1d: int = 0x33
        var s2a: int = 0x32; var s2b: int = 0x2d; var s2c: int = 0x62; var s2d: int = 0x79
        var s3a: int = 0x74; var s3b: int = 0x65; var s3c: int = 0x20; var s3d: int = 0x6b

        // s4..s11 = key bytes 0..31
        var bk0:  byte = this.key[0];  var bk1:  byte = this.key[1];  var bk2:  byte = this.key[2];  var bk3:  byte = this.key[3]
        var bk4:  byte = this.key[4];  var bk5:  byte = this.key[5];  var bk6:  byte = this.key[6];  var bk7:  byte = this.key[7]
        var bk8:  byte = this.key[8];  var bk9:  byte = this.key[9];  var bk10: byte = this.key[10]; var bk11: byte = this.key[11]
        var bk12: byte = this.key[12]; var bk13: byte = this.key[13]; var bk14: byte = this.key[14]; var bk15: byte = this.key[15]
        var bk16: byte = this.key[16]; var bk17: byte = this.key[17]; var bk18: byte = this.key[18]; var bk19: byte = this.key[19]
        var bk20: byte = this.key[20]; var bk21: byte = this.key[21]; var bk22: byte = this.key[22]; var bk23: byte = this.key[23]
        var bk24: byte = this.key[24]; var bk25: byte = this.key[25]; var bk26: byte = this.key[26]; var bk27: byte = this.key[27]
        var bk28: byte = this.key[28]; var bk29: byte = this.key[29]; var bk30: byte = this.key[30]; var bk31: byte = this.key[31]

        var s4a: int = bk0  as int; var s4b: int = bk1  as int; var s4c: int = bk2  as int; var s4d: int = bk3  as int
        var s5a: int = bk4  as int; var s5b: int = bk5  as int; var s5c: int = bk6  as int; var s5d: int = bk7  as int
        var s6a: int = bk8  as int; var s6b: int = bk9  as int; var s6c: int = bk10 as int; var s6d: int = bk11 as int
        var s7a: int = bk12 as int; var s7b: int = bk13 as int; var s7c: int = bk14 as int; var s7d: int = bk15 as int
        var s8a: int = bk16 as int; var s8b: int = bk17 as int; var s8c: int = bk18 as int; var s8d: int = bk19 as int
        var s9a: int = bk20 as int; var s9b: int = bk21 as int; var s9c: int = bk22 as int; var s9d: int = bk23 as int
        var s10a: int = bk24 as int; var s10b: int = bk25 as int; var s10c: int = bk26 as int; var s10d: int = bk27 as int
        var s11a: int = bk28 as int; var s11b: int = bk29 as int; var s11c: int = bk30 as int; var s11d: int = bk31 as int

        // s12 = counter (little-endian)
        var s12a: int = this.ctr0; var s12b: int = this.ctr1; var s12c: int = this.ctr2; var s12d: int = this.ctr3

        // s13..s15 = nonce (little-endian)
        var s13a: int = this.n0; var s13b: int = this.n1; var s13c: int = this.n2; var s13d: int = this.n3
        var s14a: int = this.n4; var s14b: int = this.n5; var s14c: int = this.n6; var s14d: int = this.n7
        var s15a: int = this.n8; var s15b: int = this.n9; var s15c: int = this.n10; var s15d: int = this.n11

        // Save initial state for final addition.
        var i0a: int = s0a; var i0b: int = s0b; var i0c: int = s0c; var i0d: int = s0d
        var i1a: int = s1a; var i1b: int = s1b; var i1c: int = s1c; var i1d: int = s1d
        var i2a: int = s2a; var i2b: int = s2b; var i2c: int = s2c; var i2d: int = s2d
        var i3a: int = s3a; var i3b: int = s3b; var i3c: int = s3c; var i3d: int = s3d
        var i4a: int = s4a; var i4b: int = s4b; var i4c: int = s4c; var i4d: int = s4d
        var i5a: int = s5a; var i5b: int = s5b; var i5c: int = s5c; var i5d: int = s5d
        var i6a: int = s6a; var i6b: int = s6b; var i6c: int = s6c; var i6d: int = s6d
        var i7a: int = s7a; var i7b: int = s7b; var i7c: int = s7c; var i7d: int = s7d
        var i8a: int = s8a; var i8b: int = s8b; var i8c: int = s8c; var i8d: int = s8d
        var i9a: int = s9a; var i9b: int = s9b; var i9c: int = s9c; var i9d: int = s9d
        var i10a: int = s10a; var i10b: int = s10b; var i10c: int = s10c; var i10d: int = s10d
        var i11a: int = s11a; var i11b: int = s11b; var i11c: int = s11c; var i11d: int = s11d
        var i12a: int = s12a; var i12b: int = s12b; var i12c: int = s12c; var i12d: int = s12d
        var i13a: int = s13a; var i13b: int = s13b; var i13c: int = s13c; var i13d: int = s13d
        var i14a: int = s14a; var i14b: int = s14b; var i14c: int = s14c; var i14d: int = s14d
        var i15a: int = s15a; var i15b: int = s15b; var i15c: int = s15c; var i15d: int = s15d

        // ---------------------------------------------------------------
        // 20 rounds = 10 double-rounds (column then diagonal).
        // Each double-round is fully unrolled.
        // Variables named r_* hold temporaries from QR computations.
        // ---------------------------------------------------------------

        // Double-round 1
        // === Column QR(s0, s4, s8, s12) ===
        var qrw: int[16] = this.QR(s0a,s0b,s0c,s0d, s4a,s4b,s4c,s4d, s8a,s8b,s8c,s8d, s12a,s12b,s12c,s12d)
        s0a  = qrw[0];  s0b  = qrw[1];  s0c  = qrw[2];  s0d  = qrw[3]
        s4a  = qrw[4];  s4b  = qrw[5];  s4c  = qrw[6];  s4d  = qrw[7]
        s8a  = qrw[8];  s8b  = qrw[9];  s8c  = qrw[10]; s8d  = qrw[11]
        s12a = qrw[12]; s12b = qrw[13]; s12c = qrw[14]; s12d = qrw[15]
        // === Column QR(s1, s5, s9, s13) ===
        qrw = this.QR(s1a,s1b,s1c,s1d, s5a,s5b,s5c,s5d, s9a,s9b,s9c,s9d, s13a,s13b,s13c,s13d)
        s1a  = qrw[0];  s1b  = qrw[1];  s1c  = qrw[2];  s1d  = qrw[3]
        s5a  = qrw[4];  s5b  = qrw[5];  s5c  = qrw[6];  s5d  = qrw[7]
        s9a  = qrw[8];  s9b  = qrw[9];  s9c  = qrw[10]; s9d  = qrw[11]
        s13a = qrw[12]; s13b = qrw[13]; s13c = qrw[14]; s13d = qrw[15]
        // === Column QR(s2, s6, s10, s14) ===
        qrw = this.QR(s2a,s2b,s2c,s2d, s6a,s6b,s6c,s6d, s10a,s10b,s10c,s10d, s14a,s14b,s14c,s14d)
        s2a  = qrw[0];  s2b  = qrw[1];  s2c  = qrw[2];  s2d  = qrw[3]
        s6a  = qrw[4];  s6b  = qrw[5];  s6c  = qrw[6];  s6d  = qrw[7]
        s10a = qrw[8];  s10b = qrw[9];  s10c = qrw[10]; s10d = qrw[11]
        s14a = qrw[12]; s14b = qrw[13]; s14c = qrw[14]; s14d = qrw[15]
        // === Column QR(s3, s7, s11, s15) ===
        qrw = this.QR(s3a,s3b,s3c,s3d, s7a,s7b,s7c,s7d, s11a,s11b,s11c,s11d, s15a,s15b,s15c,s15d)
        s3a  = qrw[0];  s3b  = qrw[1];  s3c  = qrw[2];  s3d  = qrw[3]
        s7a  = qrw[4];  s7b  = qrw[5];  s7c  = qrw[6];  s7d  = qrw[7]
        s11a = qrw[8];  s11b = qrw[9];  s11c = qrw[10]; s11d = qrw[11]
        s15a = qrw[12]; s15b = qrw[13]; s15c = qrw[14]; s15d = qrw[15]
        // === Diagonal QR(s0, s5, s10, s15) ===
        qrw = this.QR(s0a,s0b,s0c,s0d, s5a,s5b,s5c,s5d, s10a,s10b,s10c,s10d, s15a,s15b,s15c,s15d)
        s0a  = qrw[0];  s0b  = qrw[1];  s0c  = qrw[2];  s0d  = qrw[3]
        s5a  = qrw[4];  s5b  = qrw[5];  s5c  = qrw[6];  s5d  = qrw[7]
        s10a = qrw[8];  s10b = qrw[9];  s10c = qrw[10]; s10d = qrw[11]
        s15a = qrw[12]; s15b = qrw[13]; s15c = qrw[14]; s15d = qrw[15]
        // === Diagonal QR(s1, s6, s11, s12) ===
        qrw = this.QR(s1a,s1b,s1c,s1d, s6a,s6b,s6c,s6d, s11a,s11b,s11c,s11d, s12a,s12b,s12c,s12d)
        s1a  = qrw[0];  s1b  = qrw[1];  s1c  = qrw[2];  s1d  = qrw[3]
        s6a  = qrw[4];  s6b  = qrw[5];  s6c  = qrw[6];  s6d  = qrw[7]
        s11a = qrw[8];  s11b = qrw[9];  s11c = qrw[10]; s11d = qrw[11]
        s12a = qrw[12]; s12b = qrw[13]; s12c = qrw[14]; s12d = qrw[15]
        // === Diagonal QR(s2, s7, s8, s13) ===
        qrw = this.QR(s2a,s2b,s2c,s2d, s7a,s7b,s7c,s7d, s8a,s8b,s8c,s8d, s13a,s13b,s13c,s13d)
        s2a  = qrw[0];  s2b  = qrw[1];  s2c  = qrw[2];  s2d  = qrw[3]
        s7a  = qrw[4];  s7b  = qrw[5];  s7c  = qrw[6];  s7d  = qrw[7]
        s8a  = qrw[8];  s8b  = qrw[9];  s8c  = qrw[10]; s8d  = qrw[11]
        s13a = qrw[12]; s13b = qrw[13]; s13c = qrw[14]; s13d = qrw[15]
        // === Diagonal QR(s3, s4, s9, s14) ===
        qrw = this.QR(s3a,s3b,s3c,s3d, s4a,s4b,s4c,s4d, s9a,s9b,s9c,s9d, s14a,s14b,s14c,s14d)
        s3a  = qrw[0];  s3b  = qrw[1];  s3c  = qrw[2];  s3d  = qrw[3]
        s4a  = qrw[4];  s4b  = qrw[5];  s4c  = qrw[6];  s4d  = qrw[7]
        s9a  = qrw[8];  s9b  = qrw[9];  s9c  = qrw[10]; s9d  = qrw[11]
        s14a = qrw[12]; s14b = qrw[13]; s14c = qrw[14]; s14d = qrw[15]

        // Double-round 2
        qrw = this.QR(s0a,s0b,s0c,s0d, s4a,s4b,s4c,s4d, s8a,s8b,s8c,s8d, s12a,s12b,s12c,s12d)
        s0a=qrw[0]; s0b=qrw[1]; s0c=qrw[2]; s0d=qrw[3]; s4a=qrw[4]; s4b=qrw[5]; s4c=qrw[6]; s4d=qrw[7]; s8a=qrw[8]; s8b=qrw[9]; s8c=qrw[10]; s8d=qrw[11]; s12a=qrw[12]; s12b=qrw[13]; s12c=qrw[14]; s12d=qrw[15]
        qrw = this.QR(s1a,s1b,s1c,s1d, s5a,s5b,s5c,s5d, s9a,s9b,s9c,s9d, s13a,s13b,s13c,s13d)
        s1a=qrw[0]; s1b=qrw[1]; s1c=qrw[2]; s1d=qrw[3]; s5a=qrw[4]; s5b=qrw[5]; s5c=qrw[6]; s5d=qrw[7]; s9a=qrw[8]; s9b=qrw[9]; s9c=qrw[10]; s9d=qrw[11]; s13a=qrw[12]; s13b=qrw[13]; s13c=qrw[14]; s13d=qrw[15]
        qrw = this.QR(s2a,s2b,s2c,s2d, s6a,s6b,s6c,s6d, s10a,s10b,s10c,s10d, s14a,s14b,s14c,s14d)
        s2a=qrw[0]; s2b=qrw[1]; s2c=qrw[2]; s2d=qrw[3]; s6a=qrw[4]; s6b=qrw[5]; s6c=qrw[6]; s6d=qrw[7]; s10a=qrw[8]; s10b=qrw[9]; s10c=qrw[10]; s10d=qrw[11]; s14a=qrw[12]; s14b=qrw[13]; s14c=qrw[14]; s14d=qrw[15]
        qrw = this.QR(s3a,s3b,s3c,s3d, s7a,s7b,s7c,s7d, s11a,s11b,s11c,s11d, s15a,s15b,s15c,s15d)
        s3a=qrw[0]; s3b=qrw[1]; s3c=qrw[2]; s3d=qrw[3]; s7a=qrw[4]; s7b=qrw[5]; s7c=qrw[6]; s7d=qrw[7]; s11a=qrw[8]; s11b=qrw[9]; s11c=qrw[10]; s11d=qrw[11]; s15a=qrw[12]; s15b=qrw[13]; s15c=qrw[14]; s15d=qrw[15]
        qrw = this.QR(s0a,s0b,s0c,s0d, s5a,s5b,s5c,s5d, s10a,s10b,s10c,s10d, s15a,s15b,s15c,s15d)
        s0a=qrw[0]; s0b=qrw[1]; s0c=qrw[2]; s0d=qrw[3]; s5a=qrw[4]; s5b=qrw[5]; s5c=qrw[6]; s5d=qrw[7]; s10a=qrw[8]; s10b=qrw[9]; s10c=qrw[10]; s10d=qrw[11]; s15a=qrw[12]; s15b=qrw[13]; s15c=qrw[14]; s15d=qrw[15]
        qrw = this.QR(s1a,s1b,s1c,s1d, s6a,s6b,s6c,s6d, s11a,s11b,s11c,s11d, s12a,s12b,s12c,s12d)
        s1a=qrw[0]; s1b=qrw[1]; s1c=qrw[2]; s1d=qrw[3]; s6a=qrw[4]; s6b=qrw[5]; s6c=qrw[6]; s6d=qrw[7]; s11a=qrw[8]; s11b=qrw[9]; s11c=qrw[10]; s11d=qrw[11]; s12a=qrw[12]; s12b=qrw[13]; s12c=qrw[14]; s12d=qrw[15]
        qrw = this.QR(s2a,s2b,s2c,s2d, s7a,s7b,s7c,s7d, s8a,s8b,s8c,s8d, s13a,s13b,s13c,s13d)
        s2a=qrw[0]; s2b=qrw[1]; s2c=qrw[2]; s2d=qrw[3]; s7a=qrw[4]; s7b=qrw[5]; s7c=qrw[6]; s7d=qrw[7]; s8a=qrw[8]; s8b=qrw[9]; s8c=qrw[10]; s8d=qrw[11]; s13a=qrw[12]; s13b=qrw[13]; s13c=qrw[14]; s13d=qrw[15]
        qrw = this.QR(s3a,s3b,s3c,s3d, s4a,s4b,s4c,s4d, s9a,s9b,s9c,s9d, s14a,s14b,s14c,s14d)
        s3a=qrw[0]; s3b=qrw[1]; s3c=qrw[2]; s3d=qrw[3]; s4a=qrw[4]; s4b=qrw[5]; s4c=qrw[6]; s4d=qrw[7]; s9a=qrw[8]; s9b=qrw[9]; s9c=qrw[10]; s9d=qrw[11]; s14a=qrw[12]; s14b=qrw[13]; s14c=qrw[14]; s14d=qrw[15]

        // Double-round 3
        qrw = this.QR(s0a,s0b,s0c,s0d, s4a,s4b,s4c,s4d, s8a,s8b,s8c,s8d, s12a,s12b,s12c,s12d)
        s0a=qrw[0]; s0b=qrw[1]; s0c=qrw[2]; s0d=qrw[3]; s4a=qrw[4]; s4b=qrw[5]; s4c=qrw[6]; s4d=qrw[7]; s8a=qrw[8]; s8b=qrw[9]; s8c=qrw[10]; s8d=qrw[11]; s12a=qrw[12]; s12b=qrw[13]; s12c=qrw[14]; s12d=qrw[15]
        qrw = this.QR(s1a,s1b,s1c,s1d, s5a,s5b,s5c,s5d, s9a,s9b,s9c,s9d, s13a,s13b,s13c,s13d)
