namespace Livt.Crypto.Hash

using Livt.Lang.Annotations

// SHA-512 (NIST FIPS 180-4) — single-block, 1024-bit input / 512-bit output.
//
// Usage (per message, one 1024-bit block at a time):
//   1. Reset()                     — initialise H0..H7 to FIPS initial values
//   2. ProcessBlock(msg)           — compress one 128-byte block
//      Repeat 2 for each block.
//   3. GetDigest() byte[64]        — return current 512-bit digest
//
// Caller is responsible for SHA-512 padding (append 0x80, zeros, 128-bit big-endian
// bit-length) before calling ProcessBlock.
component Sha512
{
    public const BLOCK_SIZE:  int = 128
    public const DIGEST_SIZE: int = 64

    h: byte[64]    // H0..H7: 8 × 8 bytes big-endian
    W: byte[640]   // Message schedule: 80 words × 8 bytes big-endian

