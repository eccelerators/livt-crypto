        this.W[96]  = msg[96];  this.W[97]  = msg[97];  this.W[98]  = msg[98];  this.W[99]  = msg[99]
        this.W[100] = msg[100]; this.W[101] = msg[101]; this.W[102] = msg[102]; this.W[103] = msg[103]
        this.W[104] = msg[104]; this.W[105] = msg[105]; this.W[106] = msg[106]; this.W[107] = msg[107]
        this.W[108] = msg[108]; this.W[109] = msg[109]; this.W[110] = msg[110]; this.W[111] = msg[111]
        this.W[112] = msg[112]; this.W[113] = msg[113]; this.W[114] = msg[114]; this.W[115] = msg[115]
        this.W[116] = msg[116]; this.W[117] = msg[117]; this.W[118] = msg[118]; this.W[119] = msg[119]
