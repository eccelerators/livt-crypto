        this.W[60]  = msg[60];  this.W[61]  = msg[61];  this.W[62]  = msg[62];  this.W[63]  = msg[63]
        this.W[64]  = msg[64];  this.W[65]  = msg[65];  this.W[66]  = msg[66];  this.W[67]  = msg[67]
        this.W[68]  = msg[68];  this.W[69]  = msg[69];  this.W[70]  = msg[70];  this.W[71]  = msg[71]
        this.W[72]  = msg[72];  this.W[73]  = msg[73];  this.W[74]  = msg[74];  this.W[75]  = msg[75]
        this.W[76]  = msg[76];  this.W[77]  = msg[77];  this.W[78]  = msg[78];  this.W[79]  = msg[79]
        this.W[80]  = msg[80];  this.W[81]  = msg[81];  this.W[82]  = msg[82];  this.W[83]  = msg[83]
        this.W[84]  = msg[84];  this.W[85]  = msg[85];  this.W[86]  = msg[86];  this.W[87]  = msg[87]
