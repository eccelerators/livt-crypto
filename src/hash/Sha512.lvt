            var jm16p1: int = jm16 + 1; var jm16p2: int = jm16 + 2; var jm16p3: int = jm16 + 3
            var jm16p4: int = jm16 + 4; var jm16p5: int = jm16 + 5; var jm16p6: int = jm16 + 6; var jm16p7: int = jm16 + 7

