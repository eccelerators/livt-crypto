        var hh0: byte = this.h[56]; var hh1: byte = this.h[57]; var hh2: byte = this.h[58]; var hh3: byte = this.h[59]
        var hh4: byte = this.h[60]; var hh5: byte = this.h[61]; var hh6: byte = this.h[62]; var hh7: byte = this.h[63]
        var a0: byte = ha0; var a1: byte = ha1; var a2: byte = ha2; var a3: byte = ha3
        var a4: byte = ha4; var a5: byte = ha5; var a6: byte = ha6; var a7: byte = ha7
        var b0: byte = hb0; var b1: byte = hb1; var b2: byte = hb2; var b3: byte = hb3
        var b4: byte = hb4; var b5: byte = hb5; var b6: byte = hb6; var b7: byte = hb7
        var c0: byte = hc0; var c1: byte = hc1; var c2: byte = hc2; var c3: byte = hc3
        var c4: byte = hc4; var c5: byte = hc5; var c6: byte = hc6; var c7: byte = hc7
        var d0: byte = hd0; var d1: byte = hd1; var d2: byte = hd2; var d3: byte = hd3
        var d4: byte = hd4; var d5: byte = hd5; var d6: byte = hd6; var d7: byte = hd7
        var e0: byte = he0; var e1: byte = he1; var e2: byte = he2; var e3: byte = he3
        var e4: byte = he4; var e5: byte = he5; var e6: byte = he6; var e7: byte = he7
        var f0: byte = hf0; var f1: byte = hf1; var f2: byte = hf2; var f3: byte = hf3
        var f4: byte = hf4; var f5: byte = hf5; var f6: byte = hf6; var f7: byte = hf7
        var g0: byte = hg0; var g1: byte = hg1; var g2: byte = hg2; var g3: byte = hg3
        var g4: byte = hg4; var g5: byte = hg5; var g6: byte = hg6; var g7: byte = hg7
        var wh0: byte = hh0; var wh1: byte = hh1; var wh2: byte = hh2; var wh3: byte = hh3
        var wh4: byte = hh4; var wh5: byte = hh5; var wh6: byte = hh6; var wh7: byte = hh7

        // Copy first 16 words (128 bytes) from msg into this.W[0..127].
        this.W[0]   = msg[0];   this.W[1]   = msg[1];   this.W[2]   = msg[2];   this.W[3]   = msg[3]
        this.W[4]   = msg[4];   this.W[5]   = msg[5];   this.W[6]   = msg[6];   this.W[7]   = msg[7]
