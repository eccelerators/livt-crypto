    // -----------------------------------------------------------------------
    // Public API
    // -----------------------------------------------------------------------

    // Reset initialises H0..H7 to SHA-512 initial hash values (FIPS 180-4 §5.3.5).
    public fn Reset()
    {
        var init: byte[64] = [
            0x6a, 0x09, 0xe6, 0x67, 0xf3, 0xbc, 0xc9, 0x08,
            0xbb, 0x67, 0xae, 0x85, 0x84, 0xca, 0xa7, 0x3b,
            0x3c, 0x6e, 0xf3, 0x72, 0xfe, 0x94, 0xf8, 0x2b,
            0xa5, 0x4f, 0xf5, 0x3a, 0x5f, 0x1d, 0x36, 0xf1,
            0x51, 0x0e, 0x52, 0x7f, 0xad, 0xe6, 0x82, 0xd1,
            0x9b, 0x05, 0x68, 0x8c, 0x2b, 0x3e, 0x6c, 0x1f,
            0x1f, 0x83, 0xd9, 0xab, 0xfb, 0x41, 0xbd, 0x6b,
            0x5b, 0xe0, 0xcd, 0x19, 0x13, 0x7e, 0x21, 0x79]
        for (var i = 0; i < 64; i++)
        {
            this.h[i] = init[i]
        }
    }

    // ProcessBlock compresses one 128-byte (1024-bit) message block.
    // Call Reset() before the first block. For multi-block messages call
    // ProcessBlock once per block; do NOT call Reset() between blocks.
    public fn ProcessBlock(msg: byte[128])
    {
        // Initialise working variables from current hash state.
        var ha0: byte = this.h[0];  var ha1: byte = this.h[1];  var ha2: byte = this.h[2];  var ha3: byte = this.h[3]
        var ha4: byte = this.h[4];  var ha5: byte = this.h[5];  var ha6: byte = this.h[6];  var ha7: byte = this.h[7]
